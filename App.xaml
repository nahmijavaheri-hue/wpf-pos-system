<Application x:Class="PointOfSale.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PointOfSale">
    <!-- No StartupUri - I show the splash window myself in App.xaml.cs so I can
         control the loading flow. -->
    <Application.Resources>
        <ResourceDictionary>

            <!-- App colours, kept in one place so I can restyle easily later -->
            <SolidColorBrush x:Key="BgBrush"      Color="#F3F5F9"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentBrush"  Color="#2D6CDF"/>
            <SolidColorBrush x:Key="AccentDark"   Color="#1E51B0"/>
            <SolidColorBrush x:Key="SidebarBrush" Color="#16243B"/>
            <SolidColorBrush x:Key="TextBrush"    Color="#1F2933"/>
            <SolidColorBrush x:Key="MutedBrush"   Color="#7B8794"/>

            <!-- Sidebar navigation button. Highlights when it's the active screen. -->
            <Style x:Key="NavButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="#AEBED6"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="12,3"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="b" CornerRadius="10" Padding="16,12" Background="Transparent">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#22344F"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
