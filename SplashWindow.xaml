<Window x:Class="PointOfSale.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading" Height="360" Width="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize">

    <!-- The whole splash is one rounded card floating on a transparent window,
         which is what gives it the clean borderless look. -->
    <Border CornerRadius="18" Background="{StaticResource SidebarBrush}">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="◆" FontSize="54" Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Point of Sale" FontSize="32" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="Cash register system" FontSize="14"
                           Foreground="#8FA0BC" HorizontalAlignment="Center" Margin="0,4,0,0"/>

                <!-- Simple indeterminate progress bar as the "loading" cue -->
                <ProgressBar IsIndeterminate="True" Width="220" Height="4" Margin="0,28,0,0"
                             Background="#22344F" Foreground="{StaticResource AccentBrush}"
                             BorderThickness="0"/>
                <TextBlock x:Name="StatusText" Text="Starting up..." FontSize="12"
                           Foreground="#8FA0BC" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
