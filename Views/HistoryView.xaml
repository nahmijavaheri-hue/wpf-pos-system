<UserControl x:Class="PointOfSale.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Sales screen. Plan: list of past transactions on one side, and the
         receipt / line items for the selected one on the other. Placeholder for now. -->
    <Grid Margin="32">
        <StackPanel VerticalAlignment="Top">
            <TextBlock Text="Sales" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="This is where I'll show past sales and receipts." FontSize="14"
                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
